# === Database selection ===
# "postgres" (default) or "oracle"
# DB_TYPE=postgres

# === PostgreSQL connection (default) ===
PG_USER=postgres
PG_PASSWORD=
PG_HOST=localhost
PG_PORT=5432
PG_DBNAME=packing_report

# Optionally map Oracle-style schemas to PostgreSQL schemas
# PG_SCHEMA_BASIS=public
# PG_SCHEMA_METRICS=public
# PG_SCHEMA_SCRAPING=public

# === Oracle connection (if DB_TYPE=oracle) ===
# ORACLE_DB_USER=ADMIN
# ORACLE_DB_PWD=
# ORACLE_DSN=most
# ORACLE_CONFIG_DIR=/etc/

# === Required: External APIs ===
FOOTBALL_API_KEY=

# === Optional: WhoScored cached data directory ===
# SOCCERDATA_DIR=

# === Optional: Soccerdata config directory ===
# SOCCERDATA_CONFIG_DIR=

# === Optional: Pipeline config ===
# ELO_VERSION=0.1
