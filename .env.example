# === Database selection ===
# "sqlite" (default, zero setup), "postgres", or "oracle"
# DB_TYPE=sqlite

# === SQLite (default) ===
# SQLITE_PATH=packing_report.db

# === PostgreSQL ===
# Requires: docker compose up -d postgres  (or your own server)
# DB_TYPE=postgres
PG_USER=postgres
PG_PASSWORD=packing
PG_HOST=localhost
PG_PORT=5432
PG_DBNAME=packing_report

# Optionally map Oracle-style schemas to PostgreSQL schemas
# PG_SCHEMA_BASIS=public
# PG_SCHEMA_METRICS=public
# PG_SCHEMA_SCRAPING=public

# === Oracle ===
# DB_TYPE=oracle
# ORACLE_DB_USER=ADMIN
# ORACLE_DB_PWD=
# ORACLE_DSN=most
# ORACLE_CONFIG_DIR=/etc/

# === Required: External APIs ===
FOOTBALL_API_KEY=

# === WhoScored cache ===
# Directory where WhoScored data is cached (tiers.json, events/, matches/, ...)
SOCCERDATA_DIR=

# Directory containing league_dict.json and teamname_replacements.json
# Defaults to the repo's configs/ directory
# SOCCERDATA_CONFIG_DIR=

# === Optional: Pipeline config ===
# ELO_VERSION=0.1
