# === Required: Database ===
# Password for the Oracle Autonomous Database ADMIN user
ORACLE_DB_PWD=

# === Required: External APIs ===
# API key for v3.football.api-sports.io (RapidAPI)
FOOTBALL_API_KEY=

# === Optional: Oracle DB connection (defaults match a standard Oracle ADB setup) ===
# ORACLE_DB_USER=ADMIN
# ORACLE_DSN=most
# ORACLE_CONFIG_DIR=/etc/

# === Optional: WhoScored cached data directory ===
# SOCCERDATA_DIR=

# === Optional: Soccerdata config directory (league_dict.json, teamname_replacements.json, ...) ===
# Defaults to repo's own configs/ directory
# SOCCERDATA_CONFIG_DIR=

# === Optional: Pipeline config ===
# ELO_VERSION=0.1
